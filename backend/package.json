{
  "name": "arthasetu-backend",
  "version": "1.0.0",
  "description": "ArthaSetu DeFi Lending Protocol - Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:ts": "ts-node -r tsconfig-paths/register server.js",
    "migrate": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "migrate:make": "knex --knexfile knexfile.ts migrate:make"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "elliptic": "^6.5.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.2.9",
    "nodemon": "^3.1.0",
    "pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "uuid": "^8.3.2"
  }
}
